{
  "name": "rolecraft",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "prebuild": "cp node_modules/pdfjs-dist/build/pdf.worker.min.mjs public/pdf.worker.min.mjs",
    "build": "next build",
    "dev": "next dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "postinstall": "cp node_modules/pdfjs-dist/build/pdf.worker.min.mjs public/pdf.worker.min.mjs",
    "knip": "knip",
    "lint": "eslint",
    "prepare": "husky",
    "sort-pkg": "sort-package-json package.json",
    "start": "next start"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-label": "^2.1.10",
    "@radix-ui/react-progress": "^1.1.10",
    "@radix-ui/react-scroll-area": "^1.2.12",
    "@radix-ui/react-select": "^2.3.1",
    "@radix-ui/react-separator": "^1.1.10",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tabs": "^1.1.15",
    "@radix-ui/react-tooltip": "^1.2.10",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "docx": "^9.7.1",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.20.0",
    "mammoth": "^1.12.0",
    "motion": "^12.40.0",
    "next": "16.2.9",
    "next-themes": "^0.4.6",
    "pdfjs-dist": "^6.0.227",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.11.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-tailwindcss": "^4.0.4",
    "husky": "^9.1.7",
    "knip": "^6.21.0",
    "lint-staged": "^17.0.8",
    "prettier": "^3.8.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "sort-package-json": "^4.0.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "knip": {
    "$schema": "./node_modules/knip/schema.json",
    "entry": [
      "src/app/**/page.tsx",
      "src/app/**/layout.tsx"
    ],
    "project": [
      "src/**/*.{ts,tsx}"
    ],
    "ignore": [
      ".claude/**",
      ".husky/**",
      "public/**"
    ],
    "ignoreDependencies": [
      "pdfjs-dist",
      "@radix-ui/react-dialog",
      "@radix-ui/react-scroll-area",
      "motion"
    ],
    "rules": {
      "exports": "warn",
      "types": "warn",
      "dependencies": "warn"
    }
  }
}
